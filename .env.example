# Kudbee — environment template (PLACEHOLDERS ONLY — no real secrets)
#
# Mission Control and the marketing site are static / zero-build and need NO secrets.
# This template exists for FUTURE lanes that do (e.g. an optional AI Worker).
#
# Usage:
#   cp .env.example .env.local      # then fill in real values locally
# .env, .env.local, and .env.*.local are gitignored — never commit real values.

# --- Optional AI Worker (Kudbee Scribe / concierge) — only if/when enabled ---
# Get a key from your Anthropic console. Leave blank unless you are running a Worker.
ANTHROPIC_API_KEY=

# Default model id for any AI lane (example placeholder).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Optional deploy / tooling (only if a lane needs it) ---
# Cloudflare API token for wrangler deploys (placeholder — do not commit a real token).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
